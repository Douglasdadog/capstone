NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Optional alias key if your setup also uses it.
SUPABASE_SECRET_KEY=

# Email (Comm Module) — use Resend OR SMTP (mailer prefers Resend if RESEND_API_KEY is set)

# Resend: https://resend.com/api-keys — paste key (starts with re_)
RESEND_API_KEY=

# Resend free testing sender (no domain). After domain verification, use your own.
MAIL_FROM="WIS <onboarding@resend.dev>"

# Optional: SMTP instead (Gmail, etc.)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=

# Optional: IoT gateway health endpoint used by Admin "Check connection"
# Example: https://your-gateway.example/health
WIS_IOT_HEALTH_URL=

# Required for secure device push into /api/iot/ingest
# Set a long random secret and send it as either:
# - header: x-iot-ingest-key: <secret>
# - or Authorization: Bearer <secret>
WIS_IOT_INGEST_KEY=

# Legacy/device-compatible secret header for POST /api/sensor
# Device sends: X-Device-Secret: <secret>
DEVICE_SECRET=

# Sensor threshold alerting
# Warning email trigger when reading >= this value (Celsius)
WIS_SENSOR_WARN_THRESHOLD_C=40
# Critical email trigger when reading >= this value (Celsius)
WIS_SENSOR_CRITICAL_THRESHOLD_C=50
# Prevent duplicate alerts for same device+severity within this window
WIS_SENSOR_ALERT_COOLDOWN_MINUTES=10
# Alert recipient (owner). Falls back to SMTP_USER if unset.
WIS_SENSOR_ALERT_EMAIL=
